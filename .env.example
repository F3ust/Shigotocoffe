# MongoDB
MONGO_PORT=27017
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DB_NAME=shigoto_coffee

# Mongo Express Admin UI
MONGO_EXPRESS_PORT=8081

# Backend
BACKEND_PORT=5000
# Optional: set to 0.0.0.0 when the API must accept connections from WSL or other hosts (e.g. bash QA from WSL → Node on Windows).
# BIND_HOST=0.0.0.0
MONGODB_URI=mongodb://admin:admin123@localhost:27017/shigoto_coffee?authSource=admin
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api
