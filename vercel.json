{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/((?!api|uploads).*\\.[a-zA-Z0-9]+)$",
      "dest": "/frontend/$1"
    },
    {
      "src": "/((?!api|uploads).*)$",
      "dest": "/frontend/index.html"
    }
  ]
}
